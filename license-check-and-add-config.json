{
    "folder": "./",
    "license": "header.txt",
    "ignore_file": ".gitignore",
    "exact_paths_method": "EXCLUDE",
    "exact_paths": [
        "node_modules",
        ".next",
        "dist",
        "build",
        "public",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "tsconfig.tsbuildinfo",
        "next-env.d.ts",
        "knip.json",
        "license-check-and-add-config.json",
        "header.txt",
        "LICENSE",
        "README.md",
        "CHANGELOG.md",
        "ARCHITECTURE.md",
        "architecture.md",
        "DEVELOPMENT_GUIDE.md",
        "dev_log.md",
        "data_maangment.md",
        "TODOs.md"
    ],
    "file_type_method": "INCLUDE",
    "file_types": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"],
    "insert_license": false,
    "license_formats": {
        "ts|tsx|js|jsx|mjs|cjs": {
            "prepend": "/*",
            "append": " */",
            "eachLine": {
                "prepend": " * "
            }
        }
    },
    "trailing_whitespace": "TRIM"
}
