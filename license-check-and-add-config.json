{
    "license": "header.txt",
    "ignoreFile": ".gitignore",
    "ignore": [
        ".next/**",
        "build/**",
        "dist/**",
        "public/**",
        "**/*.md",
        ".github/workflows/**",
        "next-env.d.ts",
        "**/*.tsbuildinfo",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "knip.json",
        "license-check-and-add-config.json",
        "header.txt",
        "LICENSE"
    ],
    "licenseFormats": {
        "ts|tsx|js|jsx|mjs|cjs": {
            "prepend": "/*",
            "append": "*/"
        }
    },
    "trailingWhitespace": "TRIM"
}
