{
    "name": "selfhelp-frontend",
    "version": "0.0.5",
    "private": true,
    "license": "MPL-2.0",
    "scripts": {
        "dev": "next dev --turbo",
        "dev:fast": "NODE_ENV=development next dev --turbo --port 3000",
        "build": "next build",
        "start": "next start",
        "next-lint": "next lint",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:changed": "vitest run --changed",
        "test:coverage": "vitest run --coverage",
        "test:release": "npm run tsc && npm run test:coverage",
        "test:e2e": "playwright test",
        "test:golden": "playwright test e2e/golden",
        "test:a11y": "playwright test e2e/a11y",
        "test:visual": "playwright test e2e/visual",
        "test:visual:update": "playwright test e2e/visual --update-snapshots",
        "tsc": "tsc",
        "lint": "eslint . --ext .ts,.tsx",
        "lint:fix": "eslint . --ext .ts,.tsx --fix",
        "dead": "knip",
        "unused": "npx ts-unused-exports tsconfig.json --excludePathsFromReport=.next --ignoreFiles=\"page.tsx\"",
        "prune": "ts-prune",
        "headers:check": "license-check-and-add check -f license-check-and-add-config.json",
        "headers:add": "license-check-and-add add -f license-check-and-add-config.json",
        "headers:remove": "license-check-and-add remove -f license-check-and-add-config.json",
        "plugins:sync": "node scripts/plugins-sync.mjs"
    },
    "dependencies": {
        "@atlaskit/pragmatic-drag-and-drop": "^1.8.0",
        "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.5",
        "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
        "@atlaskit/pragmatic-drag-and-drop-react-drop-indicator": "^3.2.15",
        "@mantine/carousel": "^9.0.2",
        "@mantine/code-highlight": "^9.0.2",
        "@mantine/core": "^9.0.2",
        "@mantine/dates": "^9.0.2",
        "@mantine/dropzone": "^9.0.2",
        "@mantine/form": "^9.0.2",
        "@mantine/hooks": "^9.0.2",
        "@mantine/notifications": "^9.0.2",
        "@mantine/schedule": "^9.0.2",
        "@mantine/tiptap": "^9.0.2",
        "@monaco-editor/react": "^4.7.0",
        "@react-querybuilder/mantine": "^8.15.0",
        "@refinedev/core": "^5.0.12",
        "@refinedev/nextjs-router": "^7.0.5",
        "@refinedev/simple-rest": "^6.0.1",
        "@selfhelp/shared": "^1.2.2",
        "@tabler/icons-react": "^3.41.1",
        "@tanstack/react-query": "^5.99.2",
        "@tanstack/react-table": "^8.21.3",
        "@tiptap/core": "^3.22.4",
        "@tiptap/extension-color": "^3.22.4",
        "@tiptap/extension-highlight": "^3.22.4",
        "@tiptap/extension-link": "^3.22.4",
        "@tiptap/extension-mention": "^3.22.4",
        "@tiptap/extension-placeholder": "^3.22.4",
        "@tiptap/extension-subscript": "^3.22.4",
        "@tiptap/extension-superscript": "^3.22.4",
        "@tiptap/extension-task-item": "^3.22.4",
        "@tiptap/extension-task-list": "^3.22.4",
        "@tiptap/extension-text-align": "^3.22.4",
        "@tiptap/extension-text-style": "^3.22.4",
        "@tiptap/extension-underline": "^3.22.4",
        "@tiptap/pm": "^3.22.4",
        "@tiptap/react": "^3.22.4",
        "@tiptap/starter-kit": "^3.22.4",
        "@tiptap/suggestion": "^3.22.4",
        "axios": "^1.15.1",
        "date-fns": "^4.1.0",
        "dayjs": "^1.11.20",
        "dompurify": "^3.4.2",
        "embla-carousel": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "html-react-parser": "^6.0.1",
        "isomorphic-dompurify": "^3.9.0",
        "json-edit-react": "^1.29.0",
        "monaco-editor": "^0.55.1",
        "next": "^16.2.6",
        "nuqs": "^2.8.9",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-dropzone": "^15.0.0",
        "react-querybuilder": "^8.15.0",
        "tailwind-preset-mantine": "^4.0.3",
        "tippy.js": "^6.3.7",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4.2.4",
        "@tanstack/react-query-devtools": "^5.99.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-istanbul": "^4.1.8",
        "eslint": "^9.39.4",
        "eslint-config-next": "16.2.6",
        "eslint-plugin-unused-imports": "^4.4.1",
        "jsdom": "^29.1.1",
        "knip": "^6.6.0",
        "license-check-and-add": "^4.0.5",
        "msw": "^2.14.6",
        "postcss": "^8.5.10",
        "tailwindcss": "^4.2.4",
        "ts-prune": "^0.10.3",
        "ts-unused-exports": "^11.0.1",
        "typescript": "5.9.3",
        "vitest": "^4.1.8"
    },
    "overrides": {
        "monaco-editor": {
            "dompurify": "^3.4.2"
        },
        "next": {
            "postcss": "^8.5.10"
        }
    },
    "packageManager": "npm@11.12.1"
}
