# -----------------------------------------------------------------------------
# SelfHelp Frontend — environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` (or `.env`) and adjust the values for your
# machine. Both are git-ignored. Only this `.env.example` is committed — it
# serves as the canonical list of variables the app and its scripts consume.
#
#   cp .env.example .env.local
#
# After editing, restart `npm run dev` so Next.js picks up the new values.
# -----------------------------------------------------------------------------


# === Core Symfony backend URLs ===============================================

# Public Symfony base URL. Used by the browser *only* for asset URLs
# (uploads, public images, etc.). The BFF proxy (/api/*) is used for all
# API traffic, so this value is not a security boundary.
NEXT_PUBLIC_API_URL=http://localhost/symfony

# Server-side / container-internal Symfony URL. Defaults to NEXT_PUBLIC_API_URL
# when unset. Set this when the Next.js server and Symfony containers reach
# each other over a different hostname than the browser does (e.g. docker
# networking: `http://symfony-web` server-side vs `http://localhost/symfony`
# from the browser).
# SYMFONY_INTERNAL_URL=http://localhost/symfony

# Symfony API prefix mounted under the base URLs above.
SYMFONY_API_PREFIX=/cms-api/v1


# === Codegen: `npm run gen:styles` ===========================================
#
# `scripts/gen-styles-types.mjs` regenerates
# `src/types/common/styles.types.generated.ts` from the live backend schema
# endpoint (`GET <API>/admin/styles/schema`). That endpoint is behind the
# admin ACL, so the script needs either (a) a bearer JWT or (b) dev
# credentials to obtain one automatically.

# Full URL to the schema endpoint. Leave unset to derive it from
# NEXT_PUBLIC_API_URL + SYMFONY_API_PREFIX + /admin/styles/schema.
# STYLES_SCHEMA_URL=http://localhost/symfony/cms-api/v1/admin/styles/schema

# --- Auth option A: paste a JWT directly -----------------------------------
# If you already have an admin access token (e.g. from DevTools or another
# script), set it here and the generator will use it verbatim.
# STYLES_SCHEMA_TOKEN=

# --- Auth option B: let the script log in for you --------------------------
# If STYLES_SCHEMA_TOKEN is empty but these two are set, the generator POSTs
# to <API>/auth/login, grabs `data.access_token`, and uses it for the schema
# fetch. Handy for local dev — never commit real credentials here.
# STYLES_SCHEMA_EMAIL=admin@example.com
# STYLES_SCHEMA_PASSWORD=

# Override where the generated TS file is written. Default path is
# `src/types/common/styles.types.generated.ts`.
# STYLES_SCHEMA_OUTPUT=
