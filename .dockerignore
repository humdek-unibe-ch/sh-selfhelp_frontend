.next
out
.git
.github
.vscode
.idea
coverage
playwright-report
test-results
e2e
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
*.log
.env
.env.*
!.env.example
Dockerfile
.dockerignore
README.md
docs
